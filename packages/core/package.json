{
  "name": "@xstate-experiments/core",
  "version": "0.1.0",
  "description": "Core library for building behavioral experiments with XState statecharts",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "xstate": "^5.28.0"
  },
  "devDependencies": {
    "typescript": "^5.9.0",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^4.0.0",
    "vitest": "^4.1.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xstate-experiments/jsPsych2.git",
    "directory": "packages/core"
  },
  "keywords": ["xstate", "statecharts", "behavioral-experiments", "jspsych", "psychology"]
}
