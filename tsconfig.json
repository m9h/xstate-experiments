{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": true,
    "sourceMap": true
  },
  "references": [
    { "path": "packages/core" },
    { "path": "packages/plugin-html-keyboard" },
    { "path": "packages/plugin-canvas" },
    { "path": "packages/plugin-survey" },
    { "path": "packages/plugin-instructions" }
  ],
  "exclude": ["node_modules", "dist"]
}
